# ─────────────────────────────────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit .env — it contains real credentials.
# In production (Cloud Run), set these as environment
# variables in the Cloud Run service console instead.
# ─────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Email Verification (ZeroBounce) ───────────────────────
ZEROBOUNCE_API_KEY=your-zerobounce-key

# ── Gmail API (OAuth 2.0) ─────────────────────────────────
# Run `node scripts/gmail-auth-setup.js` to generate these.
# Steps:
#   1. Go to https://console.cloud.google.com
#   2. Create a project → Enable Gmail API
#   3. APIs & Services → Credentials → Create OAuth 2.0 Client ID
#      - Application type: Web application
#      - Authorized redirect URI: http://localhost:3333/callback
#   4. Run: node scripts/gmail-auth-setup.js
#   5. Paste the printed values below
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# ── Email Sender Identity ─────────────────────────────────
EMAIL_FROM=your-gmail@gmail.com
EMAIL_FROM_NAME=OptiRate

# ── Email Mode ────────────────────────────────────────────
# "mock" = no real emails sent (safe for dev/staging) [default]
# "gmail" = send via Gmail API using OAuth credentials above
EMAIL_MODE=mock

# ── Test Mode ─────────────────────────────────────────────
# When true, ALL emails are redirected to TEST_EMAIL_ADDRESS.
# Subjects are prefixed with [TEST]. Safe for testing Gmail integration.
EMAIL_TEST_MODE=false
TEST_EMAIL_ADDRESS=your-test-inbox@gmail.com

# ── Rate Limiting ─────────────────────────────────────────
# Controls send pace to protect domain reputation.
EMAIL_DAILY_CAP=50
EMAIL_HOURLY_CAP=20
EMAIL_MIN_DELAY=30000
EMAIL_MAX_DELAY=90000

# ── Scraper ───────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true

# ── Python interpreter ────────────────────────────────────
# Windows dev:  PYTHON_PATH=.venv/Scripts/python.exe
# Linux/Cloud Run: PYTHON_PATH=/usr/bin/python3  (or omit — auto-detected)
PYTHON_PATH=.venv/Scripts/python.exe

# ── API ───────────────────────────────────────────────────
API_SECRET_KEY=generate-a-random-secret-here
PORT=3001

# ── Frontend → API URL (Next.js uses NEXT_PUBLIC_ prefix) ─
# Local dev:    http://localhost:3001
# Production:   https://trustpilot-gateway-3lazv1k9.uc.gateway.dev  (API Gateway — public proxy to Cloud Run)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# ── Frontend → API Key ────────────────────────────────────
# Must match API_SECRET_KEY set on Cloud Run
NEXT_PUBLIC_API_SECRET_KEY=your-api-secret-key-here

# ── Frontend → Gemini AI ──────────────────────────────────
# Used by CampaignBuilder to generate email templates with AI
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key
