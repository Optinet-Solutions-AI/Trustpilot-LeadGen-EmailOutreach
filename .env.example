# ─────────────────────────────────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit .env — it contains real credentials.
# In production (Cloud Run), set these as environment
# variables in the Cloud Run service console instead.
# ─────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Email Verification (ZeroBounce) ───────────────────────
ZEROBOUNCE_API_KEY=your-zerobounce-key

# ── Email Sending (Resend) ────────────────────────────────
RESEND_API_KEY=re_your-resend-key
EMAIL_FROM=outreach@yourdomain.com

# ── Email Mode ────────────────────────────────────────────
# "mock" = no real emails sent (safe for dev/staging)
# "live" = uses real ZeroBounce + Resend APIs
EMAIL_MODE=mock

# ── Scraper ───────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true

# ── Python interpreter ────────────────────────────────────
# Windows dev:  PYTHON_PATH=.venv/Scripts/python.exe
# Linux/Cloud Run: PYTHON_PATH=/usr/bin/python3  (or omit — auto-detected)
PYTHON_PATH=.venv/Scripts/python.exe

# ── API ───────────────────────────────────────────────────
API_SECRET_KEY=generate-a-random-secret-here
PORT=3001

# ── Frontend → API URL ────────────────────────────────────
# Local dev:    http://localhost:3001
# Production:   https://trustpilot-gateway-3lazv1k9.uc.gateway.dev  (API Gateway — public proxy to Cloud Run)
VITE_API_BASE_URL=http://localhost:3001

# ── Frontend → Gemini AI ──────────────────────────────────
# Used by CampaignBuilder to generate email templates with AI
VITE_GEMINI_API_KEY=your-gemini-api-key
