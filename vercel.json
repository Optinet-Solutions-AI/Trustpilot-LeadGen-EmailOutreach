{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/out" }
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://trustpilot-gateway-3lazv1k9.uc.gateway.dev/api/:path*" },
    { "source": "/leads/:path*", "destination": "/leads/_id.html" }
  ]
}
